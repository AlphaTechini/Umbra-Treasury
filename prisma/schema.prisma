generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  walletAddress String   @unique @map("wallet_address")
  username      String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  daos                DAO[]
  createdTransactions TreasuryTransaction[] @relation("TransactionCreator")
  reviewedRequests    DisclosureRequest[]   @relation("DisclosureReviewer")
  generatedReports    Report[]              @relation("ReportGenerator")
  accessLogs          AccessLog[]           @relation("AccessLogActor")

  @@map("users")
}

model DAO {
  id              String    @id @default(cuid())
  ownerId         String    @map("owner_id")
  name            String
  slug            String    @unique
  treasuryAddress String?   @map("treasury_address")
  baseToken       BaseToken @map("base_token")
  description     String?
  isPublic        Boolean   @default(true) @map("is_public")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  owner              User                  @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  transactions       TreasuryTransaction[]
  disclosureRequests DisclosureRequest[]
  reports            Report[]
  accessLogs         AccessLog[]

  @@index([ownerId])
  @@map("daos")
}

model TreasuryTransaction {
  id         String              @id @default(cuid())
  daoId      String              @map("dao_id")
  type       TransactionType
  category   TransactionCategory
  token      String
  amountHint String?             @map("amount_hint")
  date       DateTime

  publicCounterpartyLabel  String? @map("public_counterparty_label")
  publicMemo               String? @map("public_memo")
  encryptedPrivateMetadata String? @map("encrypted_private_metadata")

  umbraOperationType UmbraOperationType @map("umbra_operation_type")
  umbraOperationRefs Json               @map("umbra_operation_refs")
  umbraStatus        UmbraStatus        @default(NOT_STARTED) @map("umbra_status")
  privacyStatus      PrivacyStatus      @default(PRIVATE) @map("privacy_status")

  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  dao                DAO                 @relation(fields: [daoId], references: [id], onDelete: Cascade)
  createdBy          User                @relation("TransactionCreator", fields: [createdById], references: [id], onDelete: Restrict)
  disclosureRequests DisclosureRequest[]

  @@index([daoId])
  @@index([createdById])
  @@index([daoId, date])
  @@index([daoId, category])
  @@map("treasury_transactions")
}

model DisclosureRequest {
  id    String @id @default(cuid())
  daoId String @map("dao_id")

  requesterName         String  @map("requester_name")
  requesterOrganization String? @map("requester_organization")
  requesterContact      String? @map("requester_contact")

  reason  DisclosureReason
  message String?

  requestedScope DisclosureScope @map("requested_scope")

  transactionId String?   @map("transaction_id")
  category      String?
  startDate     DateTime? @map("start_date")
  endDate       DateTime? @map("end_date")

  disclosureMethod DisclosureMethod? @map("disclosure_method")
  status           DisclosureStatus  @default(PENDING)

  fulfilledReportId String?   @unique @map("fulfilled_report_id")
  reviewedById      String?   @map("reviewed_by_id")
  reviewedAt        DateTime? @map("reviewed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  dao             DAO                  @relation(fields: [daoId], references: [id], onDelete: Cascade)
  transaction     TreasuryTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  reviewedBy      User?                @relation("DisclosureReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  fulfilledReport Report?              @relation("FulfilledReport", fields: [fulfilledReportId], references: [id], onDelete: SetNull)
  reports         Report[]             @relation("RequestReports")

  @@index([daoId])
  @@index([transactionId])
  @@index([reviewedById])
  @@index([status])
  @@map("disclosure_requests")
}

model Report {
  id                  String  @id @default(cuid())
  daoId               String  @map("dao_id")
  disclosureRequestId String? @map("disclosure_request_id")

  type               ReportType
  source             ReportSource
  verificationStatus VerificationStatus @default(UNVERIFIED) @map("verification_status")

  title     String
  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")

  generatedById String?  @map("generated_by_id")
  generatedAt   DateTime @default(now()) @map("generated_at")

  reportData Json @map("report_data")

  dao               DAO                @relation(fields: [daoId], references: [id], onDelete: Cascade)
  disclosureRequest DisclosureRequest? @relation("RequestReports", fields: [disclosureRequestId], references: [id], onDelete: SetNull)
  fulfillsRequest   DisclosureRequest? @relation("FulfilledReport")
  generatedBy       User?              @relation("ReportGenerator", fields: [generatedById], references: [id], onDelete: SetNull)

  @@index([daoId])
  @@index([disclosureRequestId])
  @@index([generatedById])
  @@index([type])
  @@index([source])
  @@map("reports")
}

model AccessLog {
  id    String @id @default(cuid())
  daoId String @map("dao_id")

  actorId    String? @map("actor_id")
  actorLabel String? @map("actor_label")

  action     AccessLogAction
  targetType AccessLogTargetType @map("target_type")
  targetId   String              @map("target_id")

  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  dao   DAO   @relation(fields: [daoId], references: [id], onDelete: Cascade)
  actor User? @relation("AccessLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([daoId])
  @@index([actorId])
  @@index([targetType, targetId])
  @@index([action])
  @@map("access_logs")
}

enum BaseToken {
  USDC
  USDT
  WSOL
  UMBRA
  OTHER
}

enum TransactionType {
  INCOME   @map("income")
  EXPENSE  @map("expense")
  TRANSFER @map("transfer")
}

enum TransactionCategory {
  GRANT             @map("grant")
  PAYROLL           @map("payroll")
  VENDOR            @map("vendor")
  OPS               @map("ops")
  TAX               @map("tax")
  TREASURY_TRANSFER @map("treasury_transfer")
  OTHER             @map("other")
}

enum UmbraOperationType {
  REGISTRATION      @map("registration")
  DEPOSIT           @map("deposit")
  WITHDRAW          @map("withdraw")
  UTXO_CREATE       @map("utxo_create")
  UTXO_CLAIM        @map("utxo_claim")
  COMPLIANCE_GRANT  @map("compliance_grant")
  COMPLIANCE_REVOKE @map("compliance_revoke")
  MOCK              @map("mock")
}

enum UmbraStatus {
  NOT_STARTED @map("not_started")
  PENDING     @map("pending")
  CONFIRMED   @map("confirmed")
  FAILED      @map("failed")
}

enum PrivacyStatus {
  PRIVATE              @map("private")
  SUMMARY_INCLUDED     @map("summary_included")
  DISCLOSURE_AVAILABLE @map("disclosure_available")
}

enum DisclosureReason {
  AUDIT            @map("audit")
  TAX              @map("tax")
  GRANT_REVIEW     @map("grant_review")
  COMMUNITY_REVIEW @map("community_review")
  INTERNAL_REVIEW  @map("internal_review")
  OTHER            @map("other")
}

enum DisclosureScope {
  SINGLE_TRANSACTION @map("single_transaction")
  CATEGORY           @map("category")
  DATE_RANGE         @map("date_range")
  FULL_REPORT        @map("full_report")
}

enum DisclosureMethod {
  VIEWING_KEY  @map("viewing_key")
  X25519_GRANT @map("x25519_grant")
  MOCK         @map("mock")
}

enum DisclosureStatus {
  PENDING   @map("pending")
  APPROVED  @map("approved")
  REJECTED  @map("rejected")
  FULFILLED @map("fulfilled")
}

enum ReportType {
  PUBLIC_SUMMARY @map("public_summary")
  AUDITOR_REPORT @map("auditor_report")
  TAX_ESTIMATE   @map("tax_estimate")
}

enum ReportSource {
  SUMMARY_ONLY     @map("summary_only")
  UMBRA_COMPLIANCE @map("umbra_compliance")
  MOCK             @map("mock")
}

enum VerificationStatus {
  UNVERIFIED @map("unverified")
  VERIFIED   @map("verified")
  FAILED     @map("failed")
}

enum AccessLogAction {
  DAO_CREATED               @map("dao_created")
  TRANSACTION_ADDED         @map("transaction_added")
  DISCLOSURE_REQUESTED      @map("disclosure_requested")
  DISCLOSURE_APPROVED       @map("disclosure_approved")
  DISCLOSURE_REJECTED       @map("disclosure_rejected")
  COMPLIANCE_GRANT_ISSUED   @map("compliance_grant_issued")
  COMPLIANCE_GRANT_REVOKED  @map("compliance_grant_revoked")
  REPORT_GENERATED          @map("report_generated")
  MOCK_DISCLOSURE_GENERATED @map("mock_disclosure_generated")
}

enum AccessLogTargetType {
  DAO                @map("dao")
  TRANSACTION        @map("transaction")
  DISCLOSURE_REQUEST @map("disclosure_request")
  REPORT             @map("report")
  UMBRA_OPERATION    @map("umbra_operation")
}
