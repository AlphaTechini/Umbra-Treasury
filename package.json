{
  "name": "umbra-treasury-disclosure",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev:api": "pnpm --filter @umbra-treasury/api dev",
    "dev:web": "pnpm --filter @umbra-treasury/web dev",
    "build:api": "pnpm --filter @umbra-treasury/api build",
    "build:web": "pnpm --filter @umbra-treasury/web build",
    "check:web": "pnpm --filter @umbra-treasury/web check",
    "start:api": "pnpm --filter @umbra-treasury/api start",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "pnpm": {
    "overrides": {
      "cookie": "0.7.2",
      "esbuild": "0.25.12"
    }
  },
  "devDependencies": {
    "dotenv": "17.4.2",
    "drizzle-kit": "0.31.10"
  }
}
